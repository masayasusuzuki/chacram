{
  "name": "chacram-vscode",
  "displayName": "CHACRAM",
  "description": "Practical VS Code companion for CHACRAM with project-aware launch behavior and a real Control Center.",
  "version": "0.2.0",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [],,
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "src/chat/**",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "chacram.start",
        "title": "CHACRAM: Launch in Terminal",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.startInWorkspaceRoot",
        "title": "CHACRAM: Launch in Workspace Root",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.openDocs",
        "title": "CHACRAM: Open Repository",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.openSetupDocs",
        "title": "CHACRAM: Open Setup Guide",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.openWorkspaceProfile",
        "title": "CHACRAM: Open Workspace Profile",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.openControlCenter",
        "title": "CHACRAM: Open Control Center",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.newChat",
        "title": "CHACRAM: New Chat",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.openChat",
        "title": "CHACRAM: Open Chat Panel",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.resumeSession",
        "title": "CHACRAM: Resume Session",
        "category": "CHACRAM"
      },
      {
        "command": "chacram.abortChat",
        "title": "CHACRAM: Abort Generation",
        "category": "CHACRAM"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chacram",
          "title": "CHACRAM",
          "icon": "media/chacram.svg"
        }
      ]
    },
    "views": {
      "chacram": [
        {
          "id": "chacram.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "chacram.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "chacram.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "CHACRAM",
      "properties": {
        "chacram.launchCommand": {
          "type": "string",
          "default": "chacram",
          "description": "Command run in the integrated terminal when launching CHACRAM."
        },
        "chacram.terminalName": {
          "type": "string",
          "default": "CHACRAM",
          "description": "Integrated terminal tab name for CHACRAM sessions."
        },
        "chacram.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched CHACRAM terminals."
        },
        "chacram.permissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": ["default", "acceptEdits", "bypassPermissions", "plan"],
          "enumDescriptions": [
            "Prompt for permission on each tool use (requires manual approval)",
            "Auto-approve file edits, prompt for other operations (recommended)",
            "Auto-approve all operations without prompting",
            "Read-only mode — no file modifications allowed"
          ],
          "description": "Permission mode for chat sessions. Controls which tool operations are auto-approved."
        }
      }
    },
    "themes": [
      {
        "label": "CHACRAM Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/CHACRAM-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node scripts/lint.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "chacram",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gitlawb/chacram"
  },
  "license": "MIT"
}
